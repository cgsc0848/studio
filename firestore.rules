rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: photos
    // Fields: id, url, title, category, aspectRatio, createdAt
    //
    // Collection: videos
    // Fields: id, thumbnail, videoUrl, title, category, description, createdAt
    //
    // Collection: settings
    // Fields: aboutTitle, aboutDesc
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "cgsc0848@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['url', 'title', 'category']) &&
             data.url is string && data.url.size() < 2000 &&
             data.title is string && data.title.size() < 200 &&
             data.category is string && data.category.size() < 100;
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['thumbnail', 'videoUrl', 'title', 'category']) &&
             data.thumbnail is string && data.thumbnail.size() < 2000 &&
             data.videoUrl is string && data.videoUrl.size() < 2000 &&
             data.title is string && data.title.size() < 200 &&
             data.category is string && data.category.size() < 100;
    }

    // Rules
    match /photos/{photoId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidPhoto(request.resource.data);
      allow delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
